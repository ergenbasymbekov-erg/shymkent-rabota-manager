# =============================================================================
# AI Recruiter v2 — environment config
# =============================================================================
#
# WHERE THIS FILE GOES (create it from this template):
#
#   /Users/erg/Desktop/second ai/ai_recruiter_v2/.env
#
# HOW IT IS LOADED:
#
#   backend/main.py → load_dotenv(ROOT / ".env")
#   backend/parser.py → os.environ["OPENAI_API_KEY"]
#
# macOS setup (run in Terminal):
#
#   cd "/Users/erg/Desktop/second ai/ai_recruiter_v2"
#   cp .env.example .env
#   nano .env          # paste your key after OPENAI_API_KEY=
#   ./run.sh
#
# Get a key: https://platform.openai.com/api-keys
#
# =============================================================================

# Required — GPT parsing will NOT work without this
OPENAI_API_KEY=

# Optional — default is gpt-4o-mini (fast + cheap, good for parsing)
OPENAI_MODEL=gpt-4o-mini

# Optional — local server port
PORT=8790

# Telegram Manager Bot (run ./run_bot.sh)
TELEGRAM_BOT_TOKEN=
# Channel username (@mychannel) or numeric id (-1001234567890)
TELEGRAM_CHANNEL_ID=
# Required — Telegram user id of the bot owner (same account works on all devices)
# Find yours: message @userinfobot on Telegram
OWNER_USER_ID=

# Manager bot — skip poster/photo for fast preview (true/false)
FAST_TEXT_ONLY_MODE=true

# Manager bot database (SQLite, WAL — scales to 100k+ vacancies)
# Default: ai_recruiter_v2/data/manager.db
# MANAGER_DB_PATH=

# Manager web (телефон / тегін хостинг) — құпия кіру коды
MANAGER_WEB_KEY=

# Серверде постер жоқ болса true; Mac-та бот үшін false болуы мүмкін
FAST_TEXT_ONLY_MODE=true
